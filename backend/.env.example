# Configuração de exemplo para produção / desenvolvimento

# Nome do projeto (apenas exibido na documentação da API)
PROJECT_NAME=ADOTE+

# String de conexão do banco de dados
# Para SQLite (desenvolvimento/local):
DATABASE_URL=sqlite:///./adote_plus.db
# Exemplo PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://usuario:senha@localhost:5432/adote_plus

# Configurações de JWT
JWT_SECRET_KEY=troque-esta-chave-para-uma-bem-segura
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=360

# Origens permitidas para CORS (frontend)
# Use ["http://localhost:5500"] em dev, ou o domínio real em produção
BACKEND_CORS_ORIGINS=["http://localhost:5500"]

# Admin padrão criado automaticamente na inicialização da API
ADMIN_DEFAULT_EMAIL=admin@adoteplus.local
ADMIN_DEFAULT_PASSWORD=Admin@123
ADMIN_DEFAULT_NAME=Administrador ADOTE+
